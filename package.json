{
  "name": "ship-master-sdk",
  "version": "1.0.0",
  "description": "Official SDK for ShipMaster, the premium event and micro-task platform on Celo. Integrated with Talent Protocol.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --watch --dts",
    "lint": "eslint src/**/*.ts",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "talent-protocol",
    "builders-score",
    "celo",
    "shipmaster",
    "web3",
    "reputation"
  ],
  "author": "earnwithalee",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Earnwithalee7890/ship-master-sdk.git"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "dependencies": {
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0",
    "eslint": "^8.0.0"
  }
}
